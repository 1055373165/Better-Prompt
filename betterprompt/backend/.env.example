# Optional override. By default the backend uses betterprompt/backend/betterprompt.db
# with an absolute repo-local path, so the database no longer drifts with the shell cwd.
BETTERPROMPT_DATABASE_URL=
# Optional: enable Base.metadata.create_all for local bootstrap only.
# Do not enable this in production once Alembic migrations are in use.
# BETTERPROMPT_DB_AUTO_CREATE=1
# BETTERPROMPT_DB_ECHO=0

BETTERPROMPT_LLM_API_KEY=your-deepseek-api-key
BETTERPROMPT_LLM_MODEL=deepseek-chat

# Optional: override if you use a non-default OpenAI-compatible provider.
BETTERPROMPT_LLM_BASE_URL=https://api.deepseek.com
# BETTERPROMPT_LLM_ENDPOINT=chat/completions
# BETTERPROMPT_LLM_TIMEOUT_SECONDS=120
# BETTERPROMPT_LLM_TEMPERATURE=0.3

# Optional: preserve the old local template behavior when LLM config is missing.
# BETTERPROMPT_ALLOW_TEMPLATE_FALLBACK=1
